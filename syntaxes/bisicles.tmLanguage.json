{
  "name": "BISICLES",
  "scopeName": "source.bisicles",
  "patterns": [
    { "include": "#comment" },
    { "include": "#placeholder" },
    { "include": "#key" },
    { "include": "#boolean" }
  ],
  "repository": {
    "comment": {
      "name": "comment.line.number-sign.bisicles",
      "match": "#.*$"
    },
    "placeholder": {
      "name": "entity.name.function.placeholder.bisicles",
      "match": "@[a-zA-Z0-9_]+"
    },
    "key": {
      "match": "^\\s*([a-zA-Z_][a-zA-Z0-9_.]*)(\\s*=)",
      "captures": {
        "1": { "name": "entity.name.tag.key.bisicles" },
        "2": { "name": "keyword.operator.assignment.bisicles" }
      }
    },
    "boolean": {
      "name": "keyword.control.boolean.bisicles",
      "match": "\\b(true|false)\\b"
    }
  }
}
